# rz-tools — MCP server credentials
#
# In normal use these keys are read from the CONSUMING repo's .env (the
# servers walk up from their own location to the nearest directory containing
# a .mcp.json and load .env from there). This file is only for running a
# server standalone from inside rz-tools for testing.

# OpenAI second-opinion review (mcp-servers/openai-{review,file-review}).
# Used by the /mcp slash command. Get a key at https://platform.openai.com.
OPENAI_API_KEY=
OPENAI_REVIEW_MODEL=gpt-5.4-mini

# xAI Grok visual workflows (mcp-servers/grok-review) — used by the
# /grok-review slash command for image / video / vision / multimodal chat.
XAI_API_KEY=
XAI_BASE_URL=https://api.x.ai/v1
GROK_TEXT_MODEL=grok-4.3
GROK_VISION_MODEL=grok-4.3
GROK_IMAGE_MODEL=grok-imagine-image
GROK_VIDEO_MODEL=grok-imagine-video
GROK_VIDEO_PATH=/videos/generations
GROK_OUTPUT_DIR=docs/grok-output
